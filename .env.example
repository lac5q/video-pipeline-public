# Required API keys
PRINTFUL_API_KEY=          # Printful API token
GOOTEN_RECIPEID=           # Gooten recipe ID for blanket/ornament
GEMINI_API_KEY=            # Google Gemini API key for staging

# AWS/Wasabi S3 (illustration upload for Printful API)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=             # Wasabi bucket name
AWS_S3_ENDPOINT=           # Wasabi endpoint URL

# Google Sheets / Drive
GOOGLE_SERVICE_ACCOUNT_KEY=    # Path to service account JSON key
GOOGLE_APPLICATION_CREDENTIALS= # Alternative: ADC credentials

# Database
DB_PATH=                       # Override default data/pipeline.db

# Optional
PIPELINE_ROOT=             # Override auto-detected pipeline root
MUSIC_DIR=                 # Override default brands/assets/music/ location

# Email (Consent System)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                     # e.g., "TurnedYellow <noreply@turnedyellow.com>"

# Consent Server
CONSENT_PORT=3000
CONSENT_BASE_URL=              # e.g., https://consent.turnedyellow.com

# Shopify (per-brand tokens for consent + coupons)
SHOPIFY_TOKEN_TURNEDYELLOW=
SHOPIFY_TOKEN_MAKEMEJEDI=
SHOPIFY_TOKEN_TURNEDWIZARD=
SHOPIFY_TOKEN_TURNEDCOMICS=
SHOPIFY_TOKEN_POPSMITHS=
