# Required API keys
PRINTFUL_API_KEY=          # Printful API token
GOOTEN_RECIPEID=           # Gooten recipe ID for blanket/ornament
GEMINI_API_KEY=            # Google Gemini API key for staging

# AWS/Wasabi S3 (illustration upload for Printful API)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=             # Wasabi bucket name
AWS_S3_ENDPOINT=           # Wasabi endpoint URL

# Optional
PIPELINE_ROOT=             # Override auto-detected pipeline root
MUSIC_DIR=                 # Override default brands/assets/music/ location
