# Media files (too large for git)
*.mp4
*.mov
*.mp3
*.aac
*.wav
*.jpg
*.jpeg
*.png

# Keep build scripts and JSON configs in orders/
!orders/*/exports/*.sh
!orders/*/*.json

# Temp build dirs
tmp_*/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# Python
__pycache__/
*.pyc
.venv/

# Per-order temp build files
orders/*/tmp_*

# Environment
.env
.env.local

# SQLite database
data/*.db
data/*.db-wal
data/*.db-shm

# Logs
logs/

# Playwright MCP
.playwright-mcp/

# Ensure brand configs and product catalog are tracked (not ignored)
!brands/*.json
!products.json
